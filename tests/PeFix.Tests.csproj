<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <ResultsDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/../artifacts/TestResults/PeFix.Tests/$(Configuration)'))</ResultsDir>
    <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --results-directory "$(ResultsDir)"</TestingPlatformCommandLineArguments>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\src\PeFix\PeFix.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
    <PackageReference Include="coverlet.MTP" Version="8.0.1" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="**/obj/**/*.cs" />
    <Compile Remove="PeFix.Tests/**/*.cs" />
    <Compile Remove="fixtures/sources/**/*.cs" />
    <Compile Remove="tools/**/*.cs" />
    <None Update="xunit.runner.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Import Project="build\fixtures.targets" />
</Project>
