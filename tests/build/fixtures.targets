<Project>

  <!--
    Single Source of Truth for staged test PE fixtures.

    PeFixSource   : real .NET assemblies compiled from sources/*.csproj.
                    Staged   = filename written under $(OutputPath)fixtures/.
                    Assembly = AssemblyName of the source project.
    PeFixDerived  : fixtures produced by byte-patching a staged source.
                    Transform = Deriver subcommand.
                    From      = PeFixSource.Staged filename to patch.
                                The 'empty' transform ignores source; a real
                                existing fixture name is used as placeholder
                                so MSBuild incrementality has a valid Input.

    Targets run AfterTargets="Build" so all ProjectReferences (fixture
    sources and Deriver) are guaranteed built before staging.
  -->

  <ItemGroup>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\CompatibleAnyCpu\CompatibleAnyCpu.csproj">
      <Staged>F01_compatible_anycpu.dll</Staged>
      <Assembly>CompatibleAnyCpu</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\X64OnlyManaged\X64OnlyManaged.csproj">
      <Staged>F02_x64only_managed.dll</Staged>
      <Assembly>X64OnlyManaged</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\X64StrongName\X64StrongName.csproj">
      <Staged>F03_x64_strongname.dll</Staged>
