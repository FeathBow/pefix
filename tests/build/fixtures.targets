    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\FieldProviderFull\FieldProviderFull.csproj">
      <Staged>F48_field_provider_full.dll</Staged>
      <Assembly>FieldProvider</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\FieldConsumer\FieldConsumer.csproj">
      <Staged>F49_field_consumer.dll</Staged>
      <Assembly>FieldConsumer</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\ImplProviderOld\ImplProviderOld.csproj">
      <Staged>F50_impl_provider_old.dll</Staged>
      <Assembly>ImplProvider</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\ImplProviderNew\ImplProviderNew.csproj">
      <Staged>F51_impl_provider_new.dll</Staged>
      <Assembly>ImplProvider</Assembly>
    </PeFixSource>
    <PeFixSource Include="$(MSBuildThisFileDirectory)..\fixtures\sources\ImplConsumer\ImplConsumer.csproj">
      <Staged>F52_impl_consumer.dll</Staged>
