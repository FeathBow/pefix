root = true

[*]
indent_style = space
indent_size = 4
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]

# Using directives
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:suggestion

# this. qualification (align: dotnet/runtime)
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Predefined types (int not Int32, string not String)
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# var preferences (align: dotnet/runtime standard)
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Modifiers
dotnet_style_require_accessibility_modifiers = always:suggestion
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:suggestion
dotnet_style_readonly_field = true:suggestion

# Expression preferences
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion

# C# expression preferences
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_simple_default_expression = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion
csharp_prefer_static_local_function = true:suggestion
csharp_prefer_braces = true:suggestion

# Formatting (align: dotnet/runtime)
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false

# Build-enforced rules — src only, TreatWarningsAsErrors promotes all to error
[src/**/*.cs]

# Unnecessary usings
dotnet_diagnostic.IDE0005.severity = warning

# var — explicit types required except when type is apparent from new/cast
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

# File-scoped namespaces required
dotnet_diagnostic.IDE0161.severity = warning

# Accessibility modifiers always required
dotnet_diagnostic.IDE0040.severity = warning

# this. qualification forbidden
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Predefined types (int/string, not Int32/String)
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Modifiers
dotnet_style_readonly_field = true:warning
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:warning

# Expression preferences
dotnet_style_object_initializer = true:warning
dotnet_style_collection_initializer = true:warning
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_auto_properties = true:warning

# C# expression preferences
csharp_prefer_simple_default_expression = true:warning
csharp_style_inlined_variable_declaration = true:warning
csharp_style_prefer_switch_expression = true:warning
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_prefer_simple_using_statement = true:warning
csharp_style_throw_expression = true:warning
csharp_style_conditional_delegate_call = true:warning
csharp_prefer_static_local_function = true:warning

# Code quality
dotnet_diagnostic.CA1031.severity = warning
dotnet_diagnostic.CA1822.severity = warning
dotnet_diagnostic.CA1852.severity = warning

# CA1515: Public types are intentional — test project references require public accessibility
dotnet_diagnostic.CA1515.severity = none

# CA1720: 'Signed' is domain terminology (digitally signed), not a C# type name
dotnet_diagnostic.CA1720.severity = none

# CA1819: Array properties on sealed records are set at construction and effectively immutable
dotnet_diagnostic.CA1819.severity = none

# MA0008: StructLayoutAttribute not required — readonly record structs are pure managed types, not interop
dotnet_diagnostic.MA0008.severity = none

[tests/**/*.cs]
# CA1707: Test method naming convention uses Subject_Predicate pattern per SPEC
dotnet_diagnostic.CA1707.severity = none
# CA1307: Assert.Contains on CLI stdout needs no StringComparison — output is ASCII
dotnet_diagnostic.CA1307.severity = none
